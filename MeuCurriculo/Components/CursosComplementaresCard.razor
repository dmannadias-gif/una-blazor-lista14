@using MeuCurriculo.Models

<div class="card mb-4 border-0 border-start border-4 border-primary shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between border-bottom pb-2 mb-2">
            <h5 class="fw-bold text-primary mb-0">@Dados.Curso</h5>
            <span class="badge bg-secondary">@Dados.Inicio - @Dados.Fim</span>
        </div>
        <h6 class="fw-semibold">@Dados.Instituicao</h6>
    </div>
</div>

@code {
    [Parameter] public CursosComplementares Dados { get; set; } = new();
}